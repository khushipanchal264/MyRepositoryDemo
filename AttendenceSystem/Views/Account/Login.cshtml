@model AttendenceSystem.Models.Employee
@{
    ViewData["Title"] = "Login";
}
<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(135deg, #4f46e5, #3b82f6);
    }   
    .login-wrapper {
        min-height: calc(100vh - 80px); /* ✅ footer space */
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 20px;
        padding-bottom: 50px; /* ✅ gap from footer */
    }
    .login-box {
        width: 100%;
        max-width: 380px;
        padding: 30px;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.2);
        color: white;
    }
        .login-box h1 {
            text-align: center;
            margin-bottom: 5px;
            font-size: 28px;
        }

    .sub {
        text-align: center;
        font-size: 14px;
        margin-bottom: 25px;
        opacity: 0.8;
    }

    .field {
        margin-bottom: 18px;
    }

        .field input {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: none;
            outline: none;
            font-size: 14px;
        }

            .field input::placeholder {
                color: #999;
            }

    .btn-login {
        width: 100%;
        padding: 12px;
        background: white;
        color: #3b82f6;
        border: none;
        border-radius: 8px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .btn-login:hover {
            background: #e0e7ff;
        }

    .error {
        color: #ff6b6b;
        text-align: center;
        margin-top: 10px;
    }

    .links {
        margin-top: 15px;
        text-align: center;
    }

        .links a {
            color: #e0e7ff;
            font-size: 13px;
            text-decoration: none;
            display: block;
            margin-top: 5px;
        }

            .links a:hover {
                text-decoration: underline;
            }
</style>

<div class="login-wrapper">
    <div class="login-box">

        <h1> Welcome 👋</h1>
        <p class="sub">Login to continue</p>

        <form method="post">

            <div class="field">
                <input asp-for="Email" type="email" placeholder="Enter your email" required />
            </div>

            <div class="field">
                <input asp-for="Password" type="password" placeholder="Enter your password" required />
            </div>

            <button type="submit" class="btn-login">Log In</button>

        </form>

        @if (ViewBag.Error != null)
        {
            <p class="error">@ViewBag.Error</p>
        }

        <div class="links">
            <a href="#">Forgot password?</a>
            <a href="/Account/Register">Create account</a>
        </div>

    </div>
</div>